@page "/projects/{projectKey}/live"
@attribute [Authorize]
@rendermode InteractiveServer

@using System.Security.Claims
@using System.Threading
@using GwsWorkforce.Web.Application.Contracts
@using GwsWorkforce.Web.Application.Models
@using GwsWorkforce.Web.Models.Workforce
@using GwsWorkforce.Web.Services
@using GwsWorkforce.Web.Services.Ollama
@using Microsoft.AspNetCore.Authorization

@inject IConversationService ConversationService
@inject IWorkerCatalogService WorkerCatalogService
@inject IChatOrchestrationService ChatOrchestrationService
@inject ProjectDraftStore ProjectDraftStore
@inject NavigationManager NavigationManager

<PageTitle>Live Collaboration</PageTitle>

<div class="pl-page" aria-busy="@isBusy">
    <header class="pl-header">
        <p class="pl-eyebrow">GWS Workforce</p>
        <h1>@projectName</h1>
        <p class="pl-subtitle">Live collaboration activity stream</p>
        <button class="btn btn-outline-primary btn-sm" @onclick="OpenProjectChats">Project Chats</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <StatusBanner Message="@errorMessage" Variant="error" />
    }

    <section class="pl-prompt-panel">
        <label class="pl-label" for="projectPrompt">Project Prompt</label>
        <textarea id="projectPrompt" class="form-control" rows="4" @bind="collaborationPrompt"
                  aria-label="Project prompt"></textarea>
        <div class="pl-prompt-actions">
            <button class="btn btn-primary" @onclick="RunUpdatedPromptAsync" disabled="@isBusy">@(isBusy ? "Running..." : "Run Updated Prompt")</button>
        </div>
    </section>

    <section class="pl-run-status" aria-live="polite" aria-label="Run status">
        <div class="pl-run-top">
            <span class="pl-dot @(activeModelRequests > 0 ? "is-working" : "is-idle")" aria-hidden="true"></span>
            <strong>@currentPhase</strong>
            <span class="pl-run-summary">@GetRunSummary()</span>
        </div>
        <div class="pl-run-action">@currentAction</div>
        @if (isBusy || planningTotal > 0 || executionTotal > 0)
        {
            <div class="pl-run-grid">
                <span>Planning</span>
                <span>@planningCompleted/@planningTotal complete</span>
                <span>@planningFailed failed</span>
                <span>Execution</span>
                <span>@executionCompleted/@executionTotal complete</span>
                <span>@executionFailed failed</span>
            </div>
        }
    </section>

    <section class="pl-terminal" aria-live="polite" aria-label="Live collaboration terminal">
        @if (activityLines.Count == 0)
        {
            <div class="pl-line">Waiting for activity...</div>
        }
        else
        {
            @foreach (var line in activityLines)
            {
                <div class="pl-line">@line</div>
            }
        }
    </section>
</div>

@code {
    [Parameter]
    public string projectKey { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "goal")]
    public string? Goal { get; set; }

    [SupplyParameterFromQuery(Name = "draft")]
    public string? Draft { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private readonly List<string> activityLines = [];
    private string? currentUserId;
    private string projectName = string.Empty;
    private string collaborationPrompt = string.Empty;
    private string errorMessage = string.Empty;
    private bool isBusy;
    private bool shouldRunInitialPrompt;
    private bool hasStartedInitialRun;
    private string currentPhase = "Idle";
    private string currentAction = "Waiting to run.";
    private int activeModelRequests;
    private int planningTotal;
    private int planningCompleted;
    private int planningFailed;
    private int executionTotal;
    private int executionCompleted;
    private int executionFailed;

    protected override async Task OnInitializedAsync()
    {
        currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            errorMessage = "Unable to determine the current user.";
            return;
        }

        projectName = ProjectNaming.DecodeProjectKey(projectKey);
        collaborationPrompt = Goal?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(collaborationPrompt) && !string.IsNullOrWhiteSpace(Draft))
        {
            collaborationPrompt = ProjectDraftStore.TakeDraft(currentUserId, Draft) ?? string.Empty;
        }

        if (string.IsNullOrWhiteSpace(collaborationPrompt))
        {
            collaborationPrompt = ProjectDraftStore.GetProjectPrompt(currentUserId, projectName) ?? string.Empty;
        }

        if (string.IsNullOrWhiteSpace(collaborationPrompt))
        {
            collaborationPrompt = await TryLoadPromptFromProjectHistoryAsync(currentUserId) ?? string.Empty;
            if (!string.IsNullOrWhiteSpace(collaborationPrompt))
            {
                ProjectDraftStore.SetProjectPrompt(currentUserId, projectName, collaborationPrompt);
            }
        }

        await LoadExistingActivityAsync(currentUserId);
        shouldRunInitialPrompt = !string.IsNullOrWhiteSpace(collaborationPrompt);

        if (!shouldRunInitialPrompt)
        {
            errorMessage = activityLines.Count == 0
                ? "No project prompt was received for this run. Return to Projects and start again."
                : string.Empty;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || hasStartedInitialRun || !shouldRunInitialPrompt || currentUserId is null)
        {
            return;
        }

        hasStartedInitialRun = true;
        await RunCollaborativeProjectAsync(currentUserId, collaborationPrompt);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RunUpdatedPromptAsync()
    {
        errorMessage = string.Empty;

        var userId = currentUserId ?? await GetCurrentUserIdAsync();
        if (userId is null)
        {
            errorMessage = "Unable to determine the current user.";
            return;
        }

        currentUserId = userId;

        if (string.IsNullOrWhiteSpace(collaborationPrompt))
        {
            errorMessage = "Project prompt is required.";
            return;
        }

        ProjectDraftStore.SetProjectPrompt(userId, projectName, collaborationPrompt.Trim());

        await RunCollaborativeProjectAsync(userId, collaborationPrompt.Trim());
    }

    private async Task RunCollaborativeProjectAsync(string userId, string goal)
    {
        errorMessage = string.Empty;
        var workers = await WorkerCatalogService.GetEnabledWorkersAsync();
        if (workers.Count == 0)
        {
            errorMessage = "At least one enabled worker is required.";
            return;
        }

        planningTotal = workers.Count;
        planningCompleted = 0;
        planningFailed = 0;
        executionTotal = 0;
        executionCompleted = 0;
        executionFailed = 0;
        currentPhase = "Stage 1/4: Concurrent Planning";
        currentAction = $"Dispatching prompt to {workers.Count} workers in parallel.";
        isBusy = true;
        activityLines.Add($"[{DateTime.Now:T}] Project kickoff started.");
        StateHasChanged();

        try
        {
            activityLines.Add($"[{DateTime.Now:T}] Using {workers.Count} chat-capable workers for this run.");
            activityLines.Add($"[{DateTime.Now:T}] Stage 1/4: Concurrent planning started.");
            StateHasChanged();

            var planningPrompt = BuildConcurrentPlanningPrompt(projectName, goal);
            var planningTasks = workers
                .Select(worker => TryRunWorkerTrackAsync(userId, worker, planningPrompt, "Plan"))
                .ToList();

            var planningCompleted = new List<WorkerTrack>();
            while (planningTasks.Count > 0)
            {
                var completedTask = await Task.WhenAny(planningTasks);
                planningTasks.Remove(completedTask);
                var result = await completedTask;

                if (result.IsSuccess)
                {
                    planningCompleted.Add(result);
                    activityLines.Add($"[{DateTime.Now:T}] {result.WorkerName} submitted planning output.");
                }
                else
                {
                    activityLines.Add($"[{DateTime.Now:T}] {result.WorkerName} failed: {result.ErrorReason}");
                }

                StateHasChanged();
            }

            if (planningCompleted.Count == 0)
            {
                var firstFailure = activityLines.LastOrDefault(x => x.Contains(" failed:", StringComparison.OrdinalIgnoreCase));
                errorMessage = string.IsNullOrWhiteSpace(firstFailure)
                    ? "All workers failed this run. Update the prompt or review worker availability."
                    : $"All workers failed this run. {firstFailure}";
                currentPhase = "Stage 1/4: Failed";
                currentAction = "No worker completed planning.";
                return;
            }

            var coordinator = SelectCoordinator(workers, planningCompleted);
            currentPhase = "Stage 2/4: Shared Plan";
            currentAction = $"{coordinator.DisplayName} is generating the shared execution plan.";
            activityLines.Add($"[{DateTime.Now:T}] Stage 2/4: {coordinator.DisplayName} is building a shared execution plan.");
            StateHasChanged();

            var sharedPlanPrompt = BuildSharedExecutionPlanPrompt(projectName, goal, planningCompleted);
            var sharedPlanResult = await SendPromptWithActivityAsync(userId, coordinator.Id, sharedPlanPrompt,
                selectedConversationId: null);

            await ConversationService.RenameConversationAsync(userId, sharedPlanResult.ConversationId,
                ProjectNaming.BuildConversationTitle(projectName, "Coordinator Plan"));

            activityLines.Add($"[{DateTime.Now:T}] Shared execution plan complete.");
            activityLines.Add($"[{DateTime.Now:T}] Stage 3/4: Sequential handoff execution started.");
            currentPhase = "Stage 3/4: Sequential Handoff";
            StateHasChanged();

            var executionOrder = OrderWorkersForExecution(workers, planningCompleted);
            var executionTracks = new List<WorkerTrack>();
            var handoffTrail = string.Empty;
            executionTotal = executionOrder.Count;

            for (var index = 0; index < executionOrder.Count; index++)
            {
                var worker = executionOrder[index];
                currentAction = $"Running sequential step {index + 1}/{executionOrder.Count} with {worker.DisplayName}.";
                var executionPrompt = BuildSequentialExecutionPrompt(
                    projectName,
                    goal,
                    sharedPlanResult.AssistantResponse,
                    handoffTrail,
                    worker,
                    index + 1,
                    executionOrder.Count);

                var executionTrack = await TryRunWorkerTrackAsync(userId, worker, executionPrompt, $"Execute {index + 1}");

                if (executionTrack.IsSuccess)
                {
                    executionTracks.Add(executionTrack);
                    activityLines.Add($"[{DateTime.Now:T}] {executionTrack.WorkerName} completed sequential step {index +
1}/{executionOrder.Count}.");

                    var contributionSnippet = TruncateForPrompt(executionTrack.Response, 1200);
                    handoffTrail += $"\n\nStep {index + 1} - {executionTrack.WorkerName}:\n{contributionSnippet}";
                }
                else
                {
                    activityLines.Add($"[{DateTime.Now:T}] {executionTrack.WorkerName} sequential step failed: {executionTrack.ErrorReason}");
                    handoffTrail += $"\n\nStep {index + 1} - {executionTrack.WorkerName}: FAILED ({executionTrack.ErrorReason})";
                }

                StateHasChanged();
            }

            activityLines.Add($"[{DateTime.Now:T}] Stage 4/4: Final collective synthesis via {coordinator.DisplayName}.");
            currentPhase = "Stage 4/4: Final Synthesis";
            currentAction = $"{coordinator.DisplayName} is producing final synthesis.";
            StateHasChanged();

            var synthesisPrompt = BuildCollectiveSynthesisPrompt(
                projectName,
                goal,
                planningCompleted,
                sharedPlanResult.AssistantResponse,
                executionTracks,
                handoffTrail);

            var collectiveResult = await SendPromptWithActivityAsync(userId, coordinator.Id, synthesisPrompt,
selectedConversationId: null);

            await ConversationService.RenameConversationAsync(userId, collectiveResult.ConversationId,
ProjectNaming.BuildConversationTitle(projectName, "Collective"));

            activityLines.Add($"[{DateTime.Now:T}] Collective synthesis complete.");
            currentPhase = "Completed";
            currentAction = "Run finished successfully.";
        }
        catch (OllamaChatException ex)
        {
            errorMessage = ex.Message;
            currentPhase = "Failed";
            currentAction = "Run failed due to model/endpoint error.";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            currentPhase = "Failed";
            currentAction = "Run failed due to configuration or validation error.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to run collaboration: {ex.Message}";
            currentPhase = "Failed";
            currentAction = "Run failed with unexpected exception.";
        }
        finally
        {
            isBusy = false;
            activeModelRequests = 0;
        }
    }

    private async Task<WorkerTrack> TryRunWorkerTrackAsync(string userId, WorkerDefinition worker, string prompt, string
trackName)
    {
        Interlocked.Increment(ref activeModelRequests);

        try
        {
            var result = await SendPromptWithActivityAsync(userId, worker.Id, prompt, selectedConversationId:
null);
            await ConversationService.RenameConversationAsync(userId, result.ConversationId,
ProjectNaming.BuildConversationTitle(projectName, $"{worker.DisplayName} {trackName}"));

            if (trackName.StartsWith("Plan", StringComparison.OrdinalIgnoreCase))
            {
                planningCompleted++;
            }
            else
            {
                executionCompleted++;
            }

            return new WorkerTrack(worker.Id, worker.DisplayName, result.AssistantResponse, true, null);
        }
        catch (Exception ex)
        {
            if (trackName.StartsWith("Plan", StringComparison.OrdinalIgnoreCase))
            {
                planningFailed++;
            }
            else
            {
                executionFailed++;
            }

            return new WorkerTrack(worker.Id, worker.DisplayName, string.Empty, false, ex.Message);
        }
        finally
        {
            Interlocked.Decrement(ref activeModelRequests);
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task<ChatSendResult> SendPromptWithActivityAsync(string userId, int workerId, string prompt, int? selectedConversationId)
    {
        return ChatOrchestrationService.SendPromptAsync(userId, workerId, prompt, selectedConversationId);
    }

    private async Task LoadExistingActivityAsync(string userId)
    {
        var projectConversations = await LoadProjectConversationsAsync(userId);

        foreach (var conversation in projectConversations)
        {
            var messages = await ConversationService.GetConversationMessagesAsync(userId, conversation.Id) ?? [];

            foreach (var message in messages.OrderBy(x => x.CreatedAtUtc))
            {
                var title = conversation.Title;
                var snippet = message.Content.Length > 140
                    ? $"{message.Content[..140]}..."
                    : message.Content;

                activityLines.Add($"[{message.CreatedAtUtc.ToLocalTime():T}] [{title}] {message.Role}: {snippet}");
            }
        }

    }

    private async Task<IReadOnlyList<Conversation>> LoadProjectConversationsAsync(string userId)
    {
        const int pageSize = 50;

        var pageNumber = 1;
        var all = new List<Conversation>();

        while (true)
        {
            var page = await ConversationService.GetUserConversationsAsync(userId, pageNumber, pageSize);
            all.AddRange(page.Items);

            if (page.PageNumber >= page.TotalPages)
            {
                break;
            }

            pageNumber++;
        }

        return all
            .Where(x => ProjectNaming.TryExtractProjectName(x.Title, out var extracted) &&
                        string.Equals(extracted, projectName, StringComparison.OrdinalIgnoreCase))
            .OrderBy(x => x.UpdatedAtUtc ?? x.CreatedAtUtc)
            .ToList();
    }

    private async Task<string?> TryLoadPromptFromProjectHistoryAsync(string userId)
    {
        var conversations = await LoadProjectConversationsAsync(userId);

        foreach (var conversation in conversations.OrderByDescending(x => x.UpdatedAtUtc ?? x.CreatedAtUtc))
        {
            var messages = await ConversationService.GetConversationMessagesAsync(userId, conversation.Id);
            if (messages is null)
            {
                continue;
            }

            foreach (var message in messages
                         .Where(x => string.Equals(x.Role, "user", StringComparison.OrdinalIgnoreCase))
                         .OrderByDescending(x => x.CreatedAtUtc))
            {
                if (TryExtractGoalFromStoredPrompt(message.Content, projectName, out var extractedGoal))
                {
                    return extractedGoal;
                }
            }
        }

        return null;
    }

    private static bool TryExtractGoalFromStoredPrompt(string content, string expectedProjectName, out string goal)
    {
        goal = string.Empty;

        if (string.IsNullOrWhiteSpace(content))
        {
            return false;
        }

        const string projectPrefix = "Project:";
        const string goalPrefix = "Goal:";

        var normalized = content.Replace("\r\n", "\n");
        var projectIndex = normalized.IndexOf(projectPrefix, StringComparison.OrdinalIgnoreCase);
        var goalIndex = normalized.IndexOf(goalPrefix, StringComparison.OrdinalIgnoreCase);

        if (projectIndex < 0 || goalIndex < 0 || goalIndex <= projectIndex)
        {
            return false;
        }

        var projectLineEnd = normalized.IndexOf('\n', projectIndex);
        if (projectLineEnd < 0)
        {
            projectLineEnd = normalized.Length;
        }

        var projectName = normalized[(projectIndex + projectPrefix.Length)..projectLineEnd].Trim();
        if (!string.Equals(projectName, expectedProjectName, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var goalStart = goalIndex + goalPrefix.Length;
        if (goalStart >= normalized.Length)
        {
            return false;
        }

        var markers = new[]
        {
            "\n\nYou are a specialist contributor",
            "\n\nThe following contributors produced planning input",
            "\n\nShared Execution Plan:",
            "\n\nThe following contributors worked in parallel:",
            "\n\nYou are a coordinated multi-model project team"
        };

        var goalEnd = normalized.Length;
        foreach (var marker in markers)
        {
            var markerIndex = normalized.IndexOf(marker, goalStart, StringComparison.OrdinalIgnoreCase);
            if (markerIndex > goalStart && markerIndex < goalEnd)
            {
                goalEnd = markerIndex;
            }
        }

        goal = normalized[goalStart..goalEnd].Trim();
        return !string.IsNullOrWhiteSpace(goal);
    }

    private static WorkerDefinition SelectCoordinator(IReadOnlyList<WorkerDefinition> availableWorkers,
IReadOnlyList<WorkerTrack> successfulTracks)
    {
        var successfulWorkerIds = successfulTracks.Select(x => x.WorkerId).ToHashSet();
        var successfulWorkers = availableWorkers.Where(x => successfulWorkerIds.Contains(x.Id)).ToList();

        return successfulWorkers.FirstOrDefault(x =>
                   x.DisplayName.Contains("general", StringComparison.OrdinalIgnoreCase) ||
                   x.Key.Contains("general", StringComparison.OrdinalIgnoreCase))
               ?? successfulWorkers[0];
    }

    private static string BuildConcurrentPlanningPrompt(string project, string goal)
    {
        return $"Project: {project}\nGoal: {goal}\n\nYou are a specialist contributor in a multi-model team. Work in parallel with other contributors. Provide concise output with:\n1. Work breakdown proposal\n2. Risks and blockers\n3. Dependencies on other contributors\n4. Concrete deliverables you can own in execution";
    }

    private static string BuildSharedExecutionPlanPrompt(string project, string goal, IReadOnlyList<WorkerTrack>
planningTracks)
    {
        var workerContributions = string.Join(
            "\n\n",
            planningTracks.Select(track =>
                $"Contributor: {track.WorkerName}\nResponse:\n{track.Response}"));

        return $"Project: {project}\nGoal: {goal}\n\nThe following contributors produced planning input in parallel:\n\n{workerContributions}\n\nCreate one shared execution plan for the team:\n1. Ordered phases\n2. Specific assignment per contributor\n3. Handoff sequence between contributors\n4. Definition of done for each phase\n\nKeep it concise and execution-ready.";
    }

    private static string BuildSequentialExecutionPrompt(
        string project,
        string goal,
        string sharedPlan,
        string handoffTrail,
        WorkerDefinition worker,
        int stepNumber,
        int totalSteps)
    {
        var trimmedTrail = TruncateForPrompt(handoffTrail, 2400);
        return $"Project: {project}\nGoal: {goal}\n\nShared Execution Plan:\n{TruncateForPrompt(sharedPlan, 2400)}\n\nCurrent Step: {stepNumber} of {totalSteps}\nCurrent Contributor: {worker.DisplayName} ({worker.Key})\n\nPrior Handoff Context:\n{(string.IsNullOrWhiteSpace(trimmedTrail) ? "No prior steps." : trimmedTrail)}\n\nExecute your assigned step now and produce:\n1. What you completed\n2. Artifacts or decisions created\n3. Risks discovered\n4. Handoff instructions for the next contributor\n\nBe concrete and concise.";
    }

    private static string BuildCollectiveSynthesisPrompt(
        string project,
        string goal,
        IReadOnlyList<WorkerTrack> planningTracks,
        string sharedPlan,
        IReadOnlyList<WorkerTrack> executionTracks,
        string handoffTrail)
    {
        var planningContributions = string.Join(
            "\n\n",
            planningTracks.Select(track =>
                $"Planning Contributor: {track.WorkerName}\nResponse:\n{TruncateForPrompt(track.Response, 1200)}"));

        var executionContributions = string.Join(
            "\n\n",
            executionTracks.Select(track =>
                $"Execution Contributor: {track.WorkerName}\nResponse:\n{TruncateForPrompt(track.Response, 1200)}"));

        return $"Project: {project}\nGoal: {goal}\n\nShared plan produced by coordinator:\n{TruncateForPrompt(sharedPlan,
1800)}\n\nParallel planning contributions:\n{planningContributions}\n\nSequential execution outcomes:\n{executionContributions}\n\nExecution handoff trail:\n{TruncateForPrompt(handoffTrail, 2000)}\n\nProvide a final collective output with:\n1. Final integrated plan\n2. What was completed vs pending\n3. Critical risks and mitigations\n4. Immediate next 3 actions";
    }

    private static List<WorkerDefinition> OrderWorkersForExecution(
        IReadOnlyList<WorkerDefinition> availableWorkers,
        IReadOnlyList<WorkerTrack> planningTracks)
    {
        var successfulIds = planningTracks.Select(x => x.WorkerId).ToHashSet();
        var successfulWorkers = availableWorkers
            .Where(x => successfulIds.Contains(x.Id))
            .OrderBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return successfulWorkers;
    }

    private static string TruncateForPrompt(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return value[..maxLength] + "\n[truncated]";
    }

    private string GetRunSummary()
    {
        if (isBusy)
        {
            return activeModelRequests > 0
                ? $"{activeModelRequests} model request(s) in-flight"
                : "Preparing next model step";
        }

        if (currentPhase.Equals("Completed", StringComparison.OrdinalIgnoreCase))
        {
            return "Idle - last run completed";
        }

        if (currentPhase.Equals("Failed", StringComparison.OrdinalIgnoreCase))
        {
            return "Idle - last run failed";
        }

        return "Idle";
    }

    private void OpenProjectChats()
    {
        NavigationManager.NavigateTo($"/projects/{projectKey}");
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        var authenticationState = AuthenticationStateTask is null ? null : await AuthenticationStateTask;
        return authenticationState?.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }

    private sealed record WorkerTrack(int WorkerId, string WorkerName, string Response, bool IsSuccess, string?
ErrorReason);
}
