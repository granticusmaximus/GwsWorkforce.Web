@page "/projects"
@attribute [Authorize]
@rendermode InteractiveServer

@using System.Security.Claims
@using GwsWorkforce.Web.Application.Contracts
@using GwsWorkforce.Web.Models.Workforce
@using GwsWorkforce.Web.Services
@using GwsWorkforce.Web.Services.Ollama
@using Microsoft.AspNetCore.Authorization

@inject IConversationService ConversationService
@inject ProjectDraftStore ProjectDraftStore
@inject NavigationManager NavigationManager

<PageTitle>Projects</PageTitle>

<div class="pj-page" aria-busy="@isLoading">
    <header class="pj-header">
        <p class="pj-eyebrow">GWS Workforce</p>
        <h1>Projects</h1>
        <p class="pj-subtitle">Create and manage collaborative projects across your worker team.</p>

        @if (!isLoading && projects.Count > 0)
        {
            <button class="btn btn-outline-primary btn-sm pj-header-create" @onclick="OpenCreateModal">New Project</button>
        }
    </header>

    @if (isLoading)
    {
        <div class="pj-loading">Loading projects...</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <StatusBanner Message="@errorMessage" Variant="error" />
        }

        @if (projects.Count == 0)
        {
            <section class="pj-empty-state">
                <button class="btn btn-primary btn-lg pj-empty-start" @onclick="OpenCreateModal">Start a New Project</button>
            </section>
        }
        else
        {
            <section class="pj-grid" aria-label="Project grid">
                @foreach (var project in projects)
                {
                    <article class="pj-folder">
                        <i class="bi bi-folder-fill pj-folder-icon" aria-hidden="true"></i>
                        <span class="pj-folder-name">@project.Name</span>
                        <span class="pj-folder-meta">@project.ConversationCount chats</span>

                        <div class="pj-folder-actions">
                            <button class="btn btn-primary btn-sm" @onclick="() => OpenProject(project.Name)">Open</button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => OpenDeleteModal(project.Name)">Delete</button>
                        </div>
                    </article>
                }
            </section>
        }
    }
</div>

@if (showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="createProjectTitle">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content pj-modal">
                <div class="modal-header">
                    <h2 id="createProjectTitle" class="modal-title fs-5">Start a New Project</h2>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <label class="pj-label" for="projectName">Project Title</label>
                    <input id="projectName" class="form-control" @bind="projectName" aria-label="Project title" />

                    <label class="pj-label mt-2" for="projectGoal">Collaboration Prompt</label>
                    <textarea id="projectGoal" class="form-control" rows="8" @bind="projectGoal"
                              aria-label="Project collaboration prompt"></textarea>
                    <p class="pj-note mt-2">All enabled workers collaborate on this one task, then a collective synthesis is
                        produced.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" @onclick="CloseCreateModal"
                                disabled="@isSubmitting">Cancel</button>
                        <button class="btn btn-primary" @onclick="StartProjectAsync" disabled="@isSubmitting">
                            @(isSubmitting ? "Starting..." : "Start")
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (!string.IsNullOrWhiteSpace(projectPendingDelete))
    {
        <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="deleteProjectTitle">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content pj-modal">
                    <div class="modal-header">
                        <h2 id="deleteProjectTitle" class="modal-title fs-5">Delete Project</h2>
                        <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteModal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Delete project <strong>@projectPendingDelete</strong> and all its chats?</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" @onclick="CloseDeleteModal"
                                disabled="@isDeletingProject">Cancel</button>
                        <button class="btn btn-danger" @onclick="DeleteProjectAsync"
                                disabled="@isDeletingProject">@(isDeletingProject ? "Deleting..." : "Delete")</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private readonly List<ProjectSummary> projects = [];

    private bool isLoading = true;
    private bool isSubmitting;
    private bool isDeletingProject;
    private bool showCreateModal;
    private string projectName = string.Empty;
    private string projectGoal = string.Empty;
    private string projectPendingDelete = string.Empty;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
        {
            errorMessage = "Unable to determine the current user.";
            isLoading = false;
            return;
        }

        await LoadProjectsAsync(userId);

        isLoading = false;
    }

    private async Task LoadProjectsAsync(string userId)
    {
        projects.Clear();

        var allConversations = await LoadAllConversationsAsync(userId);

        var grouped = allConversations
            .Select(x =>
            {
                _ = ProjectNaming.TryExtractProjectName(x.Title, out var projectNameValue);
                return new { Conversation = x, ProjectName = projectNameValue };
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.ProjectName))
            .GroupBy(x => x.ProjectName!, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var latest = group
                    .Select(x => x.Conversation)
                    .OrderByDescending(x => x.UpdatedAtUtc ?? x.CreatedAtUtc)
                    .First();

                return new ProjectSummary
                {
                    Name = group.Key,
                    ConversationCount = group.Count(),
                    LastActivityUtc = latest.UpdatedAtUtc ?? latest.CreatedAtUtc,
                    LatestConversationId = latest.Id
                };
            })
            .OrderByDescending(x => x.LastActivityUtc);

        projects.AddRange(grouped);
    }

    private async Task<IReadOnlyList<Conversation>> LoadAllConversationsAsync(string userId)
    {
        const int pageSize = 50;

        var pageNumber = 1;
        var all = new List<Conversation>();

        while (true)
        {
            var page = await ConversationService.GetUserConversationsAsync(userId, pageNumber, pageSize);
            all.AddRange(page.Items);

            if (page.PageNumber >= page.TotalPages)
            {
                break;
            }

            pageNumber++;
        }

        return all;
    }

    private async Task StartProjectAsync()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(projectName) || string.IsNullOrWhiteSpace(projectGoal))
        {
            errorMessage = "Project and goal are required.";
            return;
        }

        isSubmitting = true;

        try
        {
            var projectKey = ProjectNaming.EncodeProjectKey(projectName);
            ProjectDraftStore.SetDraft(projectKey, projectGoal.Trim());
            NavigationManager.NavigateTo($"/projects/{projectKey}/live", forceLoad: true);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void OpenCreateModal()
    {
        showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
    }

    private void OpenProject(string projectNameValue)
    {
        var projectKey = ProjectNaming.EncodeProjectKey(projectNameValue);
        NavigationManager.NavigateTo($"/projects/{projectKey}");
    }

    private void OpenDeleteModal(string projectNameValue)
    {
        projectPendingDelete = projectNameValue;
    }

    private void CloseDeleteModal()
    {
        if (isDeletingProject)
        {
            return;
        }

        projectPendingDelete = string.Empty;
    }

    private async Task DeleteProjectAsync()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(projectPendingDelete))
        {
            return;
        }

        var userId = await GetCurrentUserIdAsync();
        if (userId is null)
        {
            errorMessage = "Unable to determine the current user.";
            return;
        }

        isDeletingProject = true;

        try
        {
            var allConversations = await LoadAllConversationsAsync(userId);
            var targets = allConversations
                .Where(x => ProjectNaming.TryExtractProjectName(x.Title, out var extracted) &&
                            string.Equals(extracted, projectPendingDelete, StringComparison.OrdinalIgnoreCase))
                .Select(x => x.Id)
                .ToList();

            var failed = 0;

            foreach (var conversationId in targets)
            {
                var deleted = await ConversationService.DeleteConversationAsync(userId, conversationId);
                if (!deleted)
                {
                    failed++;
                }
            }

            await LoadProjectsAsync(userId);

            if (failed > 0)
            {
                errorMessage = $"Some chats could not be deleted ({failed}).";
            }

            projectPendingDelete = string.Empty;
        }
        finally
        {
            isDeletingProject = false;
        }
    }

    private async Task<string?> GetCurrentUserIdAsync()
    {
        var authenticationState = AuthenticationStateTask is null ? null : await AuthenticationStateTask;
        return authenticationState?.User.FindFirstValue(ClaimTypes.NameIdentifier);
    }

}
